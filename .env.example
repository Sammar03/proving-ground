# ── Backend (copy to backend/.env) ──────────────────────────────
GROQ_API_KEY=gsk_...                        # https://console.groq.com/keys (free tier)
APP_TOKEN=change-me                         # shared secret; gates every route. Required (unset → all 401)

# Local dev uses sqlite (no setup). Production uses Neon Postgres.
DATABASE_URL=sqlite:///./smoke.db
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/DBNAME   # Neon (prod)

FRONTEND_ORIGIN=http://localhost:3000       # prod: your https://<app>.vercel.app

# ── Frontend (copy to frontend/.env.local) ──────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8002   # prod: your https://<backend>.onrender.com
